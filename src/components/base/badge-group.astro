---
type Size = "md" | "lg";
type Color = "brand" | "warning" | "error" | "gray" | "success";
type Theme = "light" | "modern";
type Align = "leading" | "trailing";

export interface Props {
  addonText: string;
  size?: Size;
  color?: Color;
  theme?: Theme;
  /** Whether the addon badge is on the left (leading) or right (trailing) of the text */
  align?: Align;
  /** Pass true to hide the trailing icon entirely */
  hideIcon?: boolean;
  class?: string;
}

const {
  addonText,
  size = "md",
  color = "brand",
  theme = "light",
  align = "leading",
  hideIcon = false,
  class: className,
} = Astro.props;

const hasText = Astro.slots.has("default");
const hasIcon = !hideIcon;
const isModern = theme === "modern";

// ─── Base classes ─────────────────────────────────────────────────────────────

const baseRoot = isModern
  ? "rounded-[10px] bg-primary text-secondary shadow-xs ring-1 ring-inset ring-primary hover:bg-secondary"
  : "rounded-full ring-1 ring-inset";

const baseAddon = isModern
  ? "flex items-center rounded-md bg-primary shadow-xs ring-1 ring-inset ring-primary"
  : "rounded-full ring-1 ring-inset";

const baseIconColor = isModern ? "text-utility-gray-500" : "";

// ─── Size classes ─────────────────────────────────────────────────────────────

let sizeRoot: string;
let sizeAddon: string;
let sizeIcon: string;
let sizeDot = "";

if (align === "leading") {
  // root: pr-1 when no text AND no icon (addon-only mode), otherwise pr-2
  sizeRoot = size === "md"
    ? (!hasText && !hasIcon ? "py-1 pr-1 pl-1 text-xs font-medium" : "py-1 pr-2 pl-1 text-xs font-medium")
    : (!hasText && !hasIcon ? "py-1 pr-1 pl-1 text-sm font-medium" : "py-1 pr-2 pl-1 text-sm font-medium");

  sizeAddon = size === "md"
    ? (isModern
        ? (hasText ? "py-0.5 gap-1 px-1.5 mr-2" : "py-0.5 gap-1 px-1.5")
        : (hasText ? "px-2 py-0.5 mr-2" : "px-2 py-0.5"))
    : (isModern
        ? (hasText ? "py-0.5 gap-1.5 px-2 mr-2" : "py-0.5 gap-1.5 px-2")
        : (hasText ? "px-2.5 py-0.5 mr-2" : "px-2.5 py-0.5"));

  sizeIcon = "ml-1 size-4";
} else {
  // trailing
  sizeRoot = size === "md"
    ? (isModern ? "py-1 pr-1 pl-2.5 text-xs font-medium" : "py-1 pr-1 pl-3 text-xs font-medium")
    : "py-1 pr-1 pl-3 text-sm font-medium";

  sizeAddon = size === "md"
    ? (hasText ? "py-0.5 pr-1.5 pl-2 ml-2" : "py-0.5 pr-1.5 pl-2")
    : (isModern
        ? (hasText ? "py-0.5 pr-1.5 pl-2 ml-2" : "py-0.5 pr-1.5 pl-2")
        : (hasText ? "py-0.5 pr-2 pl-2.5 ml-2" : "py-0.5 pr-2 pl-2.5"));

  sizeIcon = size === "md" ? "ml-0.5 size-3 stroke-[3px]" : "ml-1 size-3 stroke-[3px]";
  sizeDot  = size === "md" ? "mr-1.5" : "mr-2";
}

// ─── Color classes ────────────────────────────────────────────────────────────

type ColorMap = { root?: string; addon?: string; icon?: string; dot?: string };

const lightColors: Record<Color, ColorMap> = {
  brand:   { root: "bg-utility-brand-50 text-utility-brand-700 ring-utility-brand-200 hover:bg-utility-brand-100",       addon: "bg-primary text-current ring-utility-brand-200",    icon: "text-utility-brand-500" },
  gray:    { root: "bg-utility-gray-50 text-utility-gray-700 ring-utility-gray-200 hover:bg-utility-gray-100",           addon: "bg-primary text-current ring-utility-gray-200",     icon: "text-utility-gray-500" },
  error:   { root: "bg-utility-error-50 text-utility-error-700 ring-utility-error-200 hover:bg-utility-error-100",       addon: "bg-primary text-current ring-utility-error-200",    icon: "text-utility-error-500" },
  warning: { root: "bg-utility-warning-50 text-utility-warning-700 ring-utility-warning-200 hover:bg-utility-warning-100", addon: "bg-primary text-current ring-utility-warning-200", icon: "text-utility-warning-500" },
  success: { root: "bg-utility-success-50 text-utility-success-700 ring-utility-success-200 hover:bg-utility-success-100", addon: "bg-primary text-current ring-utility-success-200", icon: "text-utility-success-500" },
};

const modernColors: Record<Color, ColorMap> = {
  brand:   { dot: "bg-utility-brand-500 outline-3 -outline-offset-1 outline-utility-brand-100" },
  gray:    { dot: "bg-utility-gray-500 outline-3 -outline-offset-1 outline-utility-gray-100" },
  error:   { dot: "bg-utility-error-500 outline-3 -outline-offset-1 outline-utility-error-100" },
  warning: { dot: "bg-utility-warning-500 outline-3 -outline-offset-1 outline-utility-warning-100" },
  success: { dot: "bg-utility-success-500 outline-3 -outline-offset-1 outline-utility-success-100" },
};

const colors = isModern ? modernColors[color] : lightColors[color];
---

{align === "leading" ? (
  <div class:list={["inline-flex w-max cursor-pointer items-center transition duration-100 ease-linear", baseRoot, sizeRoot, colors.root, className]}>
    <span class:list={["inline-flex items-center", baseAddon, sizeAddon, colors.addon]}>
      {isModern && <span class:list={["inline-block size-2 shrink-0 rounded-full", sizeDot, colors.dot]} />}
      {addonText}
    </span>

    <slot />

    {hasIcon && (
      <span class:list={["inline-flex shrink-0 [&>svg]:size-full", sizeIcon, baseIconColor, colors.icon]}>
        <slot name="icon-trailing">
          <!-- Default: arrow right icon -->
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" />
          </svg>
        </slot>
      </span>
    )}
  </div>
) : (
  <div class:list={["inline-flex w-max cursor-pointer items-center transition duration-100 ease-linear", baseRoot, sizeRoot, colors.root, className]}>
    {isModern && <span class:list={["inline-block size-2 shrink-0 rounded-full", sizeDot, colors.dot]} />}

    <slot />

    <span class:list={["inline-flex items-center", baseAddon, sizeAddon, colors.addon]}>
      {addonText}

      {hasIcon && (
        <span class:list={["inline-flex shrink-0 [&>svg]:size-full", sizeIcon, baseIconColor, colors.icon]}>
          <slot name="icon-trailing">
            <!-- Default: arrow right icon -->
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" />
            </svg>
          </slot>
        </span>
      )}
    </span>
  </div>
)}
